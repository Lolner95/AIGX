# Normalize line endings to LF on check-in, convert to native on checkout
* text=auto eol=lf

# Explicitly set LF for text formats used in this repo
*.md text eol=lf
*.aigx text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.py text eol=lf
*.cff text eol=lf

# Explicitly mark binary files
*.png binary
*.jpg binary
*.svg binary
*.ico binary

# GitHub highlighting for AIGX genome files.
# AIGX is XML-style markup. Until AIGX ships as a first-class language in
# github/linguist (contribution kit: editors/linguist/), render .aigx with XML
# highlighting and keep it out of the repo's language statistics. Remove once
# AIGX is accepted into Linguist (tm_scope: source.aigx).
*.aigx linguist-language=XML linguist-detectable=false
